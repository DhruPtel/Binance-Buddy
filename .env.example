# =============================================================================
# Binance Buddy — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — required for AI chat agent and research briefs
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=

# BSC RPC endpoint — falls back to public bsc-dataseed.binance.org if not set
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# ── Agent Wallet ───────────────────────────────────────────────────────────────

# Private key for the agent wallet (the wallet that signs and submits transactions).
# If not set, a wallet is auto-generated on first run and saved to .agent-keystore.json.
# Use a DEDICATED wallet — never your main wallet. Fund with BNB before trading.
AGENT_WALLET_PRIVATE_KEY=

# Password used to encrypt the .agent-keystore.json file.
KEYSTORE_PASSWORD=binancebuddy-dev

# ── Strongly Recommended ───────────────────────────────────────────────────────

# Moralis API key — enables full BEP-20 token discovery and transaction history
# Free tier: 40k compute units/day — get at moralis.io
# Without this: token history disabled, wallet archetype shows as 'unknown'
MORALIS_API_KEY=

# Brave Search API key — fallback for contract address resolution
# Free tier: 2,000 queries/month — get at brave.com/search/api
# Without this: protocol discovery works via DeFiLlama only (no web search fallback)
BRAVE_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# GoldRush (Covalent) API key — fallback when DeFiLlama yields endpoints return empty
# Free tier: 25,000–100,000 credits/month — get at goldrush.dev
GOLDRUSH_API_KEY=

# Dune Analytics API key — powers the Deep Research panel (on-chain SQL queries)
# Free tier: 2,500 credits/month — get at dune.com
# Without this: [Deep Research] button is unavailable
DUNE_API_KEY=

# CoinGecko API key — higher rate limits on price feeds (free tier works without key)
COINGECKO_API_KEY=

# Ankr API key — secondary RPC fallback (requires paid plan for Enhanced API)
ANKR_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────

# Telegram bot token — enables the Telegram interface
# Create a bot at t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000
