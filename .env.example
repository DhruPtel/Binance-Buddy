# =============================================================================
# Binance Buddy — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# BSC RPC (optional — falls back to public RPCs in constants.ts)
BSC_RPC_URL=

# Moralis API key (free at moralis.io — 40k compute units/day, used for tx history)
# Without this key, tx history is disabled and archetype will show as 'unknown'.
MORALIS_API_KEY=

# Ankr Enhanced API key (fallback for tx history if Moralis key not set; requires paid plan)
ANKR_API_KEY=3cbccbd1cd6ff5794c9cc1dbae7535408a8406db4146d1c8b2d18072b932bf94

# Redis (server cache for research reports & market data)
REDIS_URL=redis://localhost:6379

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Server
PORT=3000
NODE_ENV=development

# CoinGecko API key (optional — free tier works without key)
COINGECKO_API_KEY=
