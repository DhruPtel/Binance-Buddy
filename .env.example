# =============================================================================
# Binance Buddy — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# BSC RPC (optional — falls back to public RPCs in constants.ts)
BSC_RPC_URL=

# Moralis API key (free at moralis.io — 40k compute units/day, used for tx history)
# Without this key, tx history is disabled and archetype will show as 'unknown'.
MORALIS_API_KEY=

# Ankr Enhanced API key (fallback for tx history if Moralis key not set; requires paid plan)
ANKR_API_KEY=

# Redis (server cache for research reports & market data)
REDIS_URL=redis://localhost:6379

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Server
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000

# CoinGecko API key (optional — free tier works without key)
COINGECKO_API_KEY=

# Anthropic API key (required for AI chat agent — get at console.anthropic.com)
ANTHROPIC_API_KEY=

# Agent wallet — the server signs and submits transactions from this wallet.
# If not set, a new wallet will be auto-generated on first run and saved to .agent-keystore.json.
# The address will be printed to the console. Fund it with BNB before trading.
AGENT_WALLET_PRIVATE_KEY=

# Password used to encrypt the agent wallet keystore file (.agent-keystore.json).
# Default: 'binancebuddy-dev' — change this in production.
KEYSTORE_PASSWORD=binancebuddy-dev

# Brave Search API key (Phase 2 Research — optional)
# Free tier: 2000 queries/month at brave.com/search/api
# Without this key, protocol discovery works via DeFiLlama only (no web search).
BRAVE_API_KEY=

# GoldRush (Covalent) API key (Phase 3 Research — optional)
# Free tier: 25,000–100,000 credits/month at goldrush.dev
# Used as fallback when DeFiLlama yields endpoints return empty results.
# Without this key, protocols with no DeFiLlama pool data show no pool info.
GOLDRUSH_API_KEY=

# Dune Analytics API key (Phase 3 Deep Research — optional)
# Free tier: 2,500 credits/month at dune.com
# Required for Layer 3 deep research (on-chain SQL queries via predefined templates).
# Without this key, the [Deep Research] button will be unavailable.
DUNE_API_KEY=
